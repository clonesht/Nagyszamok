---
import Card from "#components/Card.astro";
import Layout from "#layouts/Layout.astro";
import { cards } from "#data/data.js";

const cardFirst = cards[0];
const cardsMore = cards.slice(1);
---

<Layout>
  <Card card={cardFirst} />
  {cardsMore.map(card => (
    <Card card={card} />
  ))}
</Layout>
